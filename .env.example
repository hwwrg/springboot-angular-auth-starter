# Local-only development defaults. Copy to .env if you want docker compose
# to load these values. Do not use these values in a deployed environment.

AUTH_STARTER_DATASOURCE_URL=jdbc:postgresql://postgres:5432/authstarter
AUTH_STARTER_DATASOURCE_USERNAME=authstarter
AUTH_STARTER_DATASOURCE_PASSWORD=authstarter

AUTH_STARTER_SERVER_PORT=8080
AUTH_STARTER_FRONTEND_ORIGIN=http://localhost:4200
AUTH_STARTER_SESSION_COOKIE_SECURE=false
AUTH_STARTER_SESSION_COOKIE_SAME_SITE=lax

AUTH_STARTER_BASELINE_AUTH_USERNAME=operator@authstarter.local
AUTH_STARTER_BASELINE_AUTH_PASSWORD=authstarter-local-password
AUTH_STARTER_BASELINE_AUTH_DISPLAY_NAME=Baseline Operator
AUTH_STARTER_BASELINE_AUTH_ROLE=SUPERADMIN
AUTH_STARTER_BASELINE_AUTH_BREAK_GLASS_ENABLED=true

AUTH_STARTER_NOTIFICATION_EMAIL_PROVIDER=local-mock
AUTH_STARTER_NOTIFICATION_EMAIL_FROM_EMAIL=no-reply@authstarter.local
AUTH_STARTER_NOTIFICATION_EMAIL_FROM_NAME=Spring Boot Angular Auth Starter
AUTH_STARTER_NOTIFICATION_EMAIL_REPLY_TO_EMAIL=

# Optional dummy SMTP values for local mail catchers such as Mailpit/MailHog.
# Set AUTH_STARTER_NOTIFICATION_EMAIL_PROVIDER=smtp to use them.
AUTH_STARTER_SMTP_HOST=localhost
AUTH_STARTER_SMTP_PORT=1025
AUTH_STARTER_SMTP_USERNAME=
AUTH_STARTER_SMTP_PASSWORD=
AUTH_STARTER_SMTP_PROTOCOL=smtp
AUTH_STARTER_SMTP_AUTH=false
AUTH_STARTER_SMTP_START_TLS=false
