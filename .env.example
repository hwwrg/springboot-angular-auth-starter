# Safe reference defaults. Copy to .env for local configuration if needed.
# Do not use this file as a deployed environment secret source.

AUTH_STARTER_DATASOURCE_URL=jdbc:postgresql://db:5432/authstarter
AUTH_STARTER_DATASOURCE_USERNAME=authstarter
AUTH_STARTER_DATASOURCE_PASSWORD=authstarter

AUTH_STARTER_SERVER_PORT=8080
AUTH_STARTER_FRONTEND_ORIGIN=http://localhost:4200
AUTH_STARTER_SESSION_COOKIE_SECURE=false
AUTH_STARTER_SESSION_COOKIE_SAME_SITE=lax

AUTH_STARTER_BASELINE_AUTH_USERNAME=
AUTH_STARTER_BASELINE_AUTH_PASSWORD=
AUTH_STARTER_BASELINE_AUTH_DISPLAY_NAME=Baseline Operator
AUTH_STARTER_BASELINE_AUTH_ROLE=USER
AUTH_STARTER_BASELINE_AUTH_BREAK_GLASS_ENABLED=false

AUTH_STARTER_GRAPHQL_MAX_QUERY_DEPTH=12
AUTH_STARTER_GRAPHQL_MAX_QUERY_COMPLEXITY=200
AUTH_STARTER_GRAPHQL_MAX_REQUEST_BYTES=32768
AUTH_STARTER_GRAPHQL_INTROSPECTION_ENABLED=false

AUTH_STARTER_NOTIFICATION_EMAIL_PROVIDER=local-mock
AUTH_STARTER_NOTIFICATION_EMAIL_FROM_EMAIL=no-reply@authstarter.local
AUTH_STARTER_NOTIFICATION_EMAIL_FROM_NAME=Spring Boot Angular Auth Starter
AUTH_STARTER_NOTIFICATION_EMAIL_REPLY_TO_EMAIL=

# Optional dummy SMTP values for local mail catchers such as Mailpit/MailHog.
# Set AUTH_STARTER_NOTIFICATION_EMAIL_PROVIDER=smtp to use them.
AUTH_STARTER_SMTP_HOST=localhost
AUTH_STARTER_SMTP_PORT=1025
AUTH_STARTER_SMTP_USERNAME=
AUTH_STARTER_SMTP_PASSWORD=
AUTH_STARTER_SMTP_PROTOCOL=smtp
AUTH_STARTER_SMTP_AUTH=false
AUTH_STARTER_SMTP_START_TLS=false

# Optional OAuth2/OIDC login. Disabled until at least one client registration
# is configured through standard Spring Security properties, for example:
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
AUTH_STARTER_OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:4200/app/dashboard
AUTH_STARTER_OAUTH2_FAILURE_REDIRECT_URL=http://localhost:4200/login
