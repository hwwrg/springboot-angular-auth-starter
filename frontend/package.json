{
  "name": "springboot-angular-auth-starter-frontend",
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:prod": "ng build --configuration production",
    "lint": "ng lint",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "20.3.24",
    "@angular/common": "20.3.24",
    "@angular/compiler": "20.3.24",
    "@angular/core": "20.3.24",
    "@angular/forms": "20.3.24",
    "@angular/platform-browser": "20.3.24",
    "@angular/router": "20.3.24",
    "@apollo/client": "4.1.8",
    "apollo-angular": "12.0.0",
    "graphql": "16.13.2",
    "lucide-angular": "0.542.0",
    "rxjs": "~7.8.2",
    "tslib": "2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/build": "20.3.24",
    "@angular/cli": "20.3.24",
    "@angular/compiler-cli": "20.3.24",
    "@eslint/js": "9.35.0",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "~5.1.15",
    "@typescript-eslint/eslint-plugin": "8.43.0",
    "@typescript-eslint/parser": "8.43.0",
    "angular-eslint": "20.7.0",
    "eslint": "9.35.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.43.0"
  }
}
